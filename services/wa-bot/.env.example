# Konfigurasi WhatsApp Bot Service
# Salin file ini menjadi .env dan sesuaikan nilainya

# Port service berjalan
PORT=3002

# Token keamanan (harus sama dengan BOT_SECRET di config.php PHP)
BOT_SECRET=RAHASIAPIXELYOGA

# Nomor WhatsApp admin (format internasional, tanpa + dan spasi)
ADMIN_WA=6285806917113

# Base URL aplikasi PHP (tanpa trailing slash)
# Untuk lokal XAMPP:
PHP_BASE_URL=http://localhost/temanamal
# Untuk produksi:
# PHP_BASE_URL=https://temanamal.org
